# ============================================================
#  Telecom RAG Assistant — Environment Configuration
#  Copy this file to `.env` and fill in your own values.
#  NEVER commit your real .env — it is gitignored.
# ============================================================

# Avoids OpenMP duplicate-library crash on some Windows setups
KMP_DUPLICATE_LIB_OK=TRUE

# --- Data paths ---
DATA_DIR_3GPP=./data/3gpp
DATA_DIR_HEDEX=./data/hedex
CHROMA_PERSIST_DIR=./chroma_db

# --- Collections ---
COLLECTION_3GPP=telecom_3gpp
COLLECTION_HEDEX=telecom_hedex

# --- Embedding + Reranker models ---
EMBED_MODEL=BAAI/bge-large-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-large

# --- Ollama (local LLM) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_TIMEOUT=120

# --- Confidence thresholds (raise = stricter, more fallback) ---
CONF_THRESHOLD_3GPP=0.45
CONF_THRESHOLD_HEDEX=0.45

# --- Retrieval ---
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5

# --- Chunking ---
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# --- OpenAI fallback (optional — leave blank to disable) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=800

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================
#  v2 options (used by the *_v2 pipeline only)
# ============================================================

# Hybrid search weights (0.0 = pure vector, 1.0 = pure BM25)
BM25_WEIGHT=0.35
VECTOR_WEIGHT=0.65

# HedEx table extraction via pdfplumber
HEDEX_USE_PDFPLUMBER=true
HEDEX_TABLE_CONFIDENCE=0.6

# 3GPP clause-prefix tagging
CLAUSE_PREFIX_ENABLED=true
